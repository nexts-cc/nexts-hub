{
  "name": "nexts-hub",
  "description": "Unified content hub for Nexts: skills, plugins, assistants, and MCP servers.",
  "categories": {
    "skills": {
      "version": 1,
      "path": "./skills/skills",
      "registry": "./skills/.agents/skills/marketplace.json",
      "installTo": "skills"
    },
    "plugins": {
      "version": 1,
      "path": "./plugins/plugins",
      "registry": "./plugins/.agents/plugins/marketplace.json",
      "installTo": "plugins"
    },
    "assistants": {
      "version": 1,
      "path": "./assistants",
      "registry": "./assistants/.agents/assistants/marketplace.json",
      "installTo": "assistants"
    },
    "mcp": {
      "version": 1,
      "path": "./mcp",
      "registry": "./mcp/.agents/mcp/marketplace.json",
      "installTo": "mcp"
    }
  }
}
