    {
      "id": "jazzhr.list_applicants",
      "service": "jazzhr",
      "name": "list_applicants",
      "description": "List JazzHR applicants with optional name, job, date, workflow status, and rating filters.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "The JazzHR result page to request. JazzHR pages start at 1 and return up to 100 records."
          },
          "name": {
            "type": "string",
            "description": "Filter applicants by any substring in first or last name."
          },
          "city": {
            "type": "string",
            "description": "Filter applicants by city."
          },
          "job_id": {
            "type": "string",
            "description": "Filter applicants by JazzHR job ID."
          },
          "job_title": {
            "type": "string",
            "description": "Filter applicants by job title."
          },
          "recruiter_id": {
            "type": "string",
            "description": "Filter applicants by recruiter ID."
          },
          "apply_date": {
            "type": "string",
            "description": "Filter applicants by exact applied date.",
            "format": "date"
          },
          "from_apply_date": {
            "type": "string",
            "description": "Only include applicants who applied on or after this date.",
            "format": "date"
          },
          "to_apply_date": {
            "type": "string",
            "description": "Only include applicants who applied on or before this date.",
            "format": "date"
          },
          "status": {
            "type": "string",
            "description": "Filter applicants by workflow status ID."
          },
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Filter applicants by rating from 1 to 5."
          }
        },
        "additionalProperties": false,
        "description": "Filters accepted by JazzHR when listing applicants."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "applicants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "A raw JazzHR record returned by the API."
            },
            "description": "JazzHR applicants returned by the API."
          },
          "raw": {
            "description": "The raw JazzHR API response payload."
          }
        },
        "additionalProperties": false,
        "required": [
          "applicants",
          "raw"
        ],
        "description": "JazzHR applicant list."
      }
    },
    {
      "id": "jazzhr.list_jobs",
      "service": "jazzhr",
      "name": "list_jobs",
      "description": "List JazzHR jobs with optional title, owner, location, date, and status filters.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "The JazzHR result page to request. JazzHR pages start at 1 and return up to 100 records."
          },
          "title": {
            "type": "string",
            "description": "Filter jobs by title."
          },
          "recruiter": {
            "type": "string",
            "description": "Filter jobs by recruiter."
          },
          "board_code": {
            "type": "string",
            "description": "Filter jobs by board code."
          },
          "department": {
            "type": "string",
            "description": "Filter jobs by department."
          },
          "hiring_lead": {
            "type": "string",
            "description": "Filter jobs by hiring lead."
          },
          "state": {
            "type": "string",
            "description": "Filter jobs by state."
          },
          "city": {
            "type": "string",
            "description": "Filter jobs by city."
          },
          "from_open_date": {
            "type": "string",
            "description": "Only include jobs opened on or after this date.",
            "format": "date"
          },
          "to_open_date": {
            "type": "string",
            "description": "Only include jobs opened on or before this date.",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "on hold",
              "approved",
              "needs approval",
              "drafting",
              "filled",
              "cancelled",
              "closed"
            ],
            "description": "The JazzHR job status filter."
          },
          "confidential": {
            "type": "boolean",
            "description": "Whether this JazzHR boolean filter should match."
          },
          "private": {
            "type": "boolean",
            "description": "Whether this JazzHR boolean filter should match."
          }
        },
        "additionalProperties": false,
        "description": "Filters accepted by JazzHR when listing jobs."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "jobs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "A raw JazzHR record returned by the API."
            },
            "description": "JazzHR jobs returned by the API."
          },
          "raw": {
            "description": "The raw JazzHR API response payload."
          }
        },
        "additionalProperties": false,
        "required": [
          "jobs",
          "raw"
        ],
        "description": "JazzHR job list."
      }
    },
