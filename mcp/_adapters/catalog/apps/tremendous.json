  ],
  "authTypes": [
    "api_key"
  ],
  "auth": [
    {
      "type": "api_key",
      "label": "API Key",
      "placeholder": "PROD_... or TEST_...",
      "description": "Tremendous API key used as a Bearer token. In production, create it from Team settings -> Developers after API access is approved: https://developers.tremendous.com/docs/production-api-access."
    }
  ],
  "homepageUrl": "https://www.tremendous.com",
  "actions": [
    {
      "id": "tremendous.create_order",
      "service": "tremendous",
      "name": "create_order",
      "description": "Create a Tremendous reward order with an optional external ID for idempotent retries.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "externalId": {
            "type": "string",
            "minLength": 1,
            "description": "A customer-supplied idempotency reference for this order."
          },
          "fundingSourceId": {
            "type": "string",
            "minLength": 1,
            "description": "The Tremendous funding source ID used to pay for the order. Use balance to use the Tremendous balance."
          },
          "campaignId": {
            "type": "string",
            "minLength": 1,
            "description": "The Tremendous campaign ID that defines the reward experience."
          },
          "products": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "description": "A Tremendous product ID."
            },
            "description": "Product IDs that the recipient can choose from. This overrides campaign products when provided.",
            "minItems": 1
          },
          "value": {
            "type": "object",
            "properties": {
              "denomination": {
                "type": "number",
                "description": "The amount of the reward."
              },
              "currency_code": {
                "type": "string",
                "minLength": 1,
                "description": "The ISO 4217 currency code for the reward."
              }
            },
            "additionalProperties": false,
            "required": [
              "denomination"
            ],
            "description": "The monetary value of the Tremendous reward."
          },
          "recipient": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "The recipient name."
              },
              "email": {
                "type": "string",
                "description": "The recipient email address.",
                "format": "email"
              },
              "phone": {
                "type": "string",
                "minLength": 1,
                "description": "The recipient phone number, including country code for non-US numbers."
              }
            },
            "additionalProperties": false,
            "description": "Details of the Tremendous reward recipient."
          },
          "deliverAt": {
            "type": "string",
            "description": "The reward delivery date. Tremendous ignores time values if a date-time is sent.",
            "format": "date"
          },
          "customFields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The Tremendous custom field ID."
                },
                "value": {
                  "type": "string",
                  "description": "The custom field value."
                }
              },
              "additionalProperties": false,
              "description": "Custom data attached to the Tremendous reward."
            },
            "description": "Custom fields to attach to the reward."
          },
          "language": {
            "type": "string",
            "minLength": 1,
            "description": "The ISO 639-1 language code for the redemption experience."
          },
          "delivery": {
            "type": "object",
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "EMAIL",
                  "LINK",
                  "PHONE"
                ],
                "description": "How Tremendous should deliver the reward."
              },
              "meta": {
                "type": "object",
                "properties": {
                  "sender_name": {
                    "type": "string",
                    "description": "The sender name used in the delivery."
                  },
                  "subject_line": {
                    "type": "string",
                    "description": "The subject line used for email delivery."
                  },
                  "message": {
                    "type": "string",
                    "description": "The message shown in the delivery and reward landing page."
                  }
                },
                "additionalProperties": true,
                "description": "Customizable Tremendous reward delivery metadata."
              }
            },
            "additionalProperties": false,
            "required": [
              "method"
            ],
            "description": "Details on how Tremendous should deliver the reward."
          }
        },
        "additionalProperties": false,
        "required": [
          "fundingSourceId",
          "value",
          "recipient"
        ],
        "description": "Input for creating one Tremendous order.",
        "anyOf": [
          {
            "required": [
              "campaignId"
            ]
          },
          {
            "required": [
              "products"
            ]
          }
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "order": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "A Tremendous order object."
          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Raw Tremendous create order response payload."
          }
        },
        "additionalProperties": false,
        "description": "A Tremendous order creation response."
      }
    },
