      "id": "tremendous.list_orders",
      "service": "tremendous",
      "name": "list_orders",
      "description": "List Tremendous orders with optional pagination and order filters.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer",
            "minimum": 0,
            "description": "The zero-based Tremendous result offset."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500,
            "description": "The maximum number of Tremendous records to return. Tremendous caps list pages at 500."
          },
          "campaignId": {
            "type": "string",
            "minLength": 1,
            "description": "Only return orders for this Tremendous campaign ID."
          },
          "externalId": {
            "type": "string",
            "minLength": 1,
            "description": "Only return orders with this customer-supplied external ID."
          },
          "createdAtGte": {
            "type": "string",
            "description": "Only return orders created at or after this ISO 8601 timestamp.",
            "format": "date-time"
          },
          "createdAtLte": {
            "type": "string",
            "description": "Only return orders created at or before this ISO 8601 timestamp.",
            "format": "date-time"
          }
        },
        "additionalProperties": false,
        "description": "Input for listing Tremendous orders."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "orders": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "A Tremendous order object."
            },
            "description": "The Tremendous orders matching the request."
          },
          "totalCount": {
            "type": "integer",
            "description": "The total number of Tremendous orders across all pages."
          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Raw Tremendous list orders response payload."
          }
        },
        "additionalProperties": false,
        "description": "Tremendous orders returned by the API."
      }
