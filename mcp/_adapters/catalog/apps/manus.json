      "description": "List Manus task event messages with cursor pagination.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1,
            "description": "The task ID to list messages for."
          },
          "limit": {
            "type": "integer",
