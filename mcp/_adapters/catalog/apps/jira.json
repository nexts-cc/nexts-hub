        "write:jira-work"
      ],
      "providerPermissions": [
        "write:jira-work"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectKey": {
            "type": "string",
            "minLength": 1,
            "description": "Jira project key."
          },
          "projectId": {
            "type": "string",
            "minLength": 1,
            "description": "Jira project ID."
          },
          "issueTypeId": {
            "type": "string",
            "minLength": 1,
            "description": "Jira issue type ID."
          },
          "issueTypeName": {
            "type": "string",
            "minLength": 1,
            "description": "Jira issue type name."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Jira issue summary."
          },
          "descriptionText": {
            "type": "string",
            "minLength": 1,
            "description": "Plain text description converted to ADF."
          },
          "description": {
            "type": "object",
            "properties": {
              "type": {
                "const": "doc",
                "type": "string",
                "description": "ADF root node type."
              },
              "version": {
                "type": "integer",
                "description": "ADF document version."
              },
              "content": {
                "type": "array",
                "items": {
                  "description": "ADF top-level node."
                },
                "description": "ADF content nodes."
              }
            },
            "additionalProperties": true,
            "required": [
              "type",
              "version",
              "content"
            ],
            "description": "Atlassian Document Format document."
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Jira labels.",
            "minItems": 1
          },
          "assigneeAccountId": {
            "type": "string",
            "minLength": 1,
            "description": "Assignee account ID."
          },
          "priorityId": {
            "type": "string",
            "minLength": 1,
            "description": "Jira priority ID."
          },
          "dueDate": {
            "type": "string",
            "description": "Jira due date in YYYY-MM-DD format.",
            "format": "date"
          },
          "parentIssueKey": {
            "type": "string",
            "minLength": 1,
            "description": "Parent issue key for subtasks."
          },
          "extraFields": {
            "type": "object",
            "additionalProperties": true,
            "description": "Jira API object."
          }
        },
        "additionalProperties": false,
        "required": [
          "summary"
        ],
        "description": "The input payload for this action."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "issue": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Jira issue ID."
              },
              "key": {
                "type": "string",
                "description": "Jira issue key."
              },
              "summary": {
                "type": "string",
                "description": "Jira issue summary."
              },
              "fields": {
                "type": "object",
                "additionalProperties": true,
                "description": "Jira API object."
              },
              "raw": {
                "type": "object",
                "additionalProperties": true,
                "description": "Jira API object."
              }
            },
            "additionalProperties": true,
            "description": "Jira issue."
          }
        },
        "additionalProperties": false,
        "required": [
          "issue"
        ],
        "description": "Jira action output."
      }
    },
