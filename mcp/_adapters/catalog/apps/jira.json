  ],
  "authTypes": [
    "oauth2"
  ],
  "auth": [
    {
      "type": "oauth2",
      "authorizationUrl": "https://auth.atlassian.com/authorize",
      "tokenUrl": "https://auth.atlassian.com/oauth/token",
      "scopes": [
        "read:jira-work",
        "read:jira-user",
        "write:jira-work",
        "offline_access"
      ],
      "tokenEndpointAuthMethod": "client_secret_post",
      "tokenRequestFormat": "json",
      "authorizationParams": {
        "audience": "api.atlassian.com",
        "prompt": "consent"
      }
    }
  ],
  "homepageUrl": "https://www.atlassian.com/software/jira",
  "actions": [
    {
      "id": "jira.add_comment",
      "service": "jira",
      "name": "add_comment",
      "description": "Add a comment to one Jira issue.",
      "requiredScopes": [
        "write:jira-work"
      ],
      "providerPermissions": [
        "write:jira-work"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issueIdOrKey": {
            "type": "string",
            "minLength": 1,
            "description": "Jira issue ID or key."
          },
          "bodyText": {
            "type": "string",
            "minLength": 1,
            "description": "Plain text comment body converted to ADF."
          },
          "body": {
            "type": "object",
            "properties": {
              "type": {
                "const": "doc",
                "type": "string",
                "description": "ADF root node type."
              },
              "version": {
                "type": "integer",
                "description": "ADF document version."
              },
              "content": {
                "type": "array",
                "items": {
                  "description": "ADF top-level node."
                },
                "description": "ADF content nodes."
              }
            },
            "additionalProperties": true,
            "required": [
              "type",
              "version",
              "content"
            ],
            "description": "Atlassian Document Format document."
          }
        },
        "additionalProperties": false,
        "required": [
          "issueIdOrKey"
        ],
        "description": "The input payload for this action."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "comment": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Jira comment ID."
              },
              "body": {
                "type": "object",
                "properties": {
                  "type": {
                    "const": "doc",
                    "type": "string",
                    "description": "ADF root node type."
                  },
                  "version": {
                    "type": "integer",
                    "description": "ADF document version."
                  },
                  "content": {
                    "type": "array",
                    "items": {
                      "description": "ADF top-level node."
                    },
                    "description": "ADF content nodes."
                  }
                },
                "additionalProperties": true,
                "required": [
                  "type",
                  "version",
                  "content"
                ],
                "description": "Atlassian Document Format document."
              },
              "raw": {
                "type": "object",
                "additionalProperties": true,
                "description": "Jira API object."
              }
            },
            "additionalProperties": true,
            "description": "Jira comment."
          }
        },
        "additionalProperties": false,
        "required": [
          "comment"
        ],
        "description": "Jira action output."
      }
    },
    {
      "id": "jira.create_issue",
      "service": "jira",
      "name": "create_issue",
      "description": "Create a Jira issue and return the normalized issue detail.",
