    {
      "id": "jira.list_issue_comments",
      "service": "jira",
      "name": "list_issue_comments",
      "description": "List comments for one Jira issue.",
      "requiredScopes": [
        "read:jira-work",
        "read:jira-user"
      ],
      "providerPermissions": [
        "read:jira-work",
        "read:jira-user"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issueIdOrKey": {
            "type": "string",
            "minLength": 1,
            "description": "Jira issue ID or key."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Maximum items to return in one Jira page."
          },
          "cursor": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "StartAt pagination cursor as a non-negative integer string."
          },
          "expand": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "description": "Jira expand token."
            },
            "description": "Additional Jira expand tokens.",
            "minItems": 1
          }
        },
        "additionalProperties": false,
        "required": [
          "issueIdOrKey"
        ],
        "description": "The input payload for this action."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "comments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Jira comment ID."
                },
                "body": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "const": "doc",
                      "type": "string",
                      "description": "ADF root node type."
                    },
                    "version": {
                      "type": "integer",
                      "description": "ADF document version."
                    },
                    "content": {
                      "type": "array",
                      "items": {
                        "description": "ADF top-level node."
                      },
                      "description": "ADF content nodes."
                    }
                  },
                  "additionalProperties": true,
                  "required": [
                    "type",
                    "version",
                    "content"
                  ],
                  "description": "Atlassian Document Format document."
                },
                "raw": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "Jira API object."
                }
              },
              "additionalProperties": true,
              "description": "Jira comment."
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "nextCursor": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Cursor for the next page."
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "additionalProperties": false,
            "required": [
              "nextCursor"
            ],
            "description": "Jira pagination metadata."
          }
        },
        "additionalProperties": false,
        "required": [
          "comments",
          "pagination"
        ],
        "description": "Jira action output."
      }
    },
