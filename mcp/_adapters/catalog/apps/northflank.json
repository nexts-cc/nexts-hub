              "deployment": {
                "type": "object",
                "properties": {},
                "additionalProperties": true,
                "description": "Deployment configuration returned by Northflank."
              },
              "ports": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true,
                  "description": "Northflank port."
