            "additionalProperties": true,
            "required": [
              "id",
              "appId",
              "name",
              "projectId",
              "serviceType",
              "createdAt",
              "disabledCI",
              "disabledCD"
            ],
            "description": "Northflank service details."
          }
        },
        "additionalProperties": false,
        "required": [
          "service"
        ],
        "description": "Northflank service detail response."
      }
