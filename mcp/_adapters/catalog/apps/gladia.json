              "id": {
                "type": "string",
                "minLength": 1,
                "description": "The unique transcription job identifier."
              },
              "requestId": {
                "type": "string",
                "description": "The request identifier for debugging."
              },
              "version": {
                "type": "integer",
                "description": "The Gladia API version used for this job."
              },
              "status": {
                "type": "string",
