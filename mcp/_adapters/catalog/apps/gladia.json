              },
              "createdAt": {
                "type": "string",
                "description": "The ISO timestamp when the job was created."
              },
              "completedAt": {
                "type": "string",
                "description": "The ISO timestamp when the job completed or failed."
              },
              "kind": {
                "type": "string",
                "description": "The Gladia job kind, usually pre-recorded."
              },
              "errorCode": {
                "type": "integer",
