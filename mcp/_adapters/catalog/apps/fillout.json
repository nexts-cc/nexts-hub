              {
                "type": "string",
                "description": "The deleted submission ID when Fillout returns it."
              },
              {
                "type": "null"
              }
            ]
          },
          "raw": {
            "description": "The raw response returned by Fillout."
          }
        },
        "additionalProperties": false,
        "required": [
          "deleted",
          "submissionId",
          "raw"
        ],
        "description": "The normalized Fillout delete-submission response."
      }
