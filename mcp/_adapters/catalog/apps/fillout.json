      "id": "fillout.create_submissions",
      "service": "fillout",
      "name": "create_submissions",
      "description": "Create one or more submissions for a Fillout form.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "formId": {
            "type": "string",
            "minLength": 1,
            "description": "The Fillout form ID."
          },
          "submissions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "One submission object accepted by Fillout."
            },
            "description": "The submissions to create in Fillout.",
            "minItems": 1,
            "maxItems": 10
          }
        },
        "additionalProperties": false,
        "required": [
          "formId",
          "submissions"
        ],
        "description": "Input payload for creating Fillout submissions."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "submissions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "submissionId": {
                  "type": "string",
                  "description": "The Fillout submission ID."
                },
                "submissionTime": {
                  "type": "string",
                  "description": "The timestamp when the submission was received."
                },
                "lastUpdatedAt": {
                  "type": "string",
                  "description": "The timestamp when the submission was last updated."
                },
                "questions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "questionId": {
                        "type": "string",
                        "description": "The Fillout question ID."
                      },
                      "name": {
                        "type": "string",
                        "description": "The question label or name."
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "ShortAnswer",
                          "LongAnswer",
                          "EmailInput",
                          "MultipleChoice",
                          "Checkboxes",
                          "Dropdown",
                          "FileUpload",
                          "DatePicker",
                          "NumberInput",
                          "PhoneNumber",
                          "CurrencyInput",
                          "Payment",
                          "Signature",
                          "Address",
                          "Slider",
                          "Rating",
                          "OpinionScale",
                          "Switch",
                          "Password",
                          "HiddenField",
                          "Table",
                          "Matrix",
                          "Captcha",
                          "ImagePicker",
                          "ColorPicker"
                        ],
                        "description": "The Fillout question type."
                      },
                      "value": {
                        "description": "The answer value returned by Fillout for this question type."
                      }
                    },
                    "additionalProperties": true,
                    "description": "One answer returned for a Fillout submission."
                  },
                  "description": "The answers returned for this submission."
                },
                "calculations": {
                  "type": "array",
                  "items": {
                    "description": "One calculation entry."
                  },
                  "description": "The calculated values returned for this submission."
                },
                "urlParameters": {
                  "description": "URL parameters captured with the submission."
                },
                "quiz": {
                  "description": "The quiz result payload when Fillout includes it."
                },
                "documents": {
                  "type": "array",
                  "items": {
                    "description": "One document payload."
                  },
                  "description": "The generated documents attached to the submission."
                },
                "scheduling": {
                  "description": "The scheduling payload when Fillout includes it."
                },
                "payments": {
                  "type": "array",
                  "items": {
                    "description": "One payment payload."
                  },
                  "description": "The payment payloads attached to the submission."
                }
              },
              "additionalProperties": true,
              "description": "One Fillout form submission."
            },
            "description": "The submissions created by Fillout."
          },
          "raw": {
            "type": "object",
            "additionalProperties": {
              "description": "A raw Fillout response value."
            },
            "description": "The raw response object returned by Fillout."
          }
        },
        "additionalProperties": false,
        "required": [
          "submissions",
          "raw"
        ],
        "description": "The normalized Fillout create-submissions response."
