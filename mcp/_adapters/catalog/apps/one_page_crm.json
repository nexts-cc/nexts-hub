        {
          "key": "userId",
          "label": "User ID",
          "inputType": "text",
          "required": true,
          "secret": false,
          "placeholder": "ONEPAGECRM_USER_ID",
          "description": "OnePageCRM user_id used as the Basic Auth username. Find it in your OnePageCRM API configuration tab after signing in: https://app.onepagecrm.com/app/api."
