        {
          "key": "apiKey",
          "label": "API Key",
          "inputType": "password",
          "required": true,
          "secret": true,
          "placeholder": "ONEPAGECRM_API_KEY",
          "description": "OnePageCRM API key used as the Basic Auth password. View or regenerate it in your OnePageCRM API configuration tab: https://app.onepagecrm.com/app/api."
