    {
      "id": "lemon_squeezy.create_webhook",
      "service": "lemon_squeezy",
      "name": "create_webhook",
      "description": "Create a Lemon Squeezy webhook for the specified store.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeId": {
            "type": "integer",
            "minimum": 1,
            "description": "The Lemon Squeezy store ID."
          },
          "url": {
            "type": "string",
            "description": "Webhook endpoint URL.",
            "format": "uri"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "customer_updated",
                "order_created",
                "order_refunded",
                "subscription_created",
                "subscription_updated",
                "subscription_cancelled",
                "subscription_resumed",
                "subscription_expired",
                "subscription_paused",
                "subscription_unpaused",
                "subscription_payment_success",
                "subscription_payment_failed",
                "subscription_payment_recovered",
                "subscription_payment_refunded",
                "license_key_created",
                "license_key_updated",
                "affiliate_activated"
              ],
              "description": "A Lemon Squeezy webhook event type."
            },
            "description": "Webhook events that should trigger deliveries.",
            "minItems": 1
          },
          "secret": {
            "type": "string",
            "minLength": 1,
            "description": "Signing secret used to verify webhook deliveries."
          }
        },
        "additionalProperties": false,
        "description": "Input for creating a webhook."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "webhook": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "The created Lemon Squeezy webhook."
          },
          "meta": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Top-level metadata returned by Lemon Squeezy."
          },
          "links": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "description": "Document link URL."
            },
            "description": "Top-level document links returned by Lemon Squeezy."
          },
          "jsonapi": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "JSON:API metadata returned by Lemon Squeezy."
          }
        },
        "additionalProperties": false,
        "required": [
          "webhook"
        ],
        "description": "Lemon Squeezy single-resource response."
      }
    },
