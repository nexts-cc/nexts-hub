      "id": "lemon_squeezy.create_customer",
      "service": "lemon_squeezy",
      "name": "create_customer",
      "description": "Create a Lemon Squeezy customer for the specified store.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeId": {
            "type": "integer",
            "minimum": 1,
            "description": "The Lemon Squeezy store ID."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Full name of the customer."
          },
          "email": {
            "type": "string",
            "description": "Email address of the customer.",
            "format": "email"
          },
          "city": {
            "type": "string",
            "minLength": 1,
            "description": "City of the customer."
          },
          "region": {
            "type": "string",
            "minLength": 1,
            "description": "Region or state of the customer."
          },
          "country": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "ISO 3166-1 alpha-2 country code of the customer."
          }
        },
        "additionalProperties": false,
        "required": [
          "storeId",
          "name",
          "email"
        ],
        "description": "Input for creating a customer."
      },
      "outputSchema": {
        "type": "object",
