      "id": "lemon_squeezy.delete_webhook",
      "service": "lemon_squeezy",
      "name": "delete_webhook",
      "description": "Delete a Lemon Squeezy webhook by ID. The returned acknowledgement is generated locally because Lemon Squeezy responds with 204 No Content.",
