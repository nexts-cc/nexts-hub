        {
          "key": "baseUrl",
          "label": "Connect Server URL",
          "inputType": "text",
          "required": true,
          "secret": false,
          "placeholder": "https://onepassword-connect.example.com",
          "description": "The root URL of your 1Password Connect Server, such as https://onepassword-connect.example.com."
        }
      ]
    }
