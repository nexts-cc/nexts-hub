              },
              "status": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The deploy status returned by Rollbar."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "userId": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "The Rollbar user ID."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "startTime": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "The deploy start timestamp."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "finishTime": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "The deploy finish timestamp."
