                    {
                      "type": "null"
                    }
                  ]
                },
                "count": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "description": "The mention count returned by Rosette."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "entityId": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The entity identifier returned by Rosette."
                    },
                    {
                      "type": "null"
                    }
