                },
                "confidence": {
                  "anyOf": [
                    {
                      "type": "number",
                      "description": "The entity confidence score returned by Rosette."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "linkingConfidence": {
                  "anyOf": [
                    {
