                },
                "mentionOffsets": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "startOffset": {
                        "type": "integer",
                        "description": "The starting character offset for the mention."
                      },
                      "endOffset": {
                        "type": "integer",
                        "description": "The ending character offset for the mention."
                      }
                    },
                    "additionalProperties": true,
                    "description": "One mention offset object returned by Rosette."
