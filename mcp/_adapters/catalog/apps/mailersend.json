      "id": "mailersend.send_email",
      "service": "mailersend",
      "name": "send_email",
      "description": "Send a transactional email through MailerSend.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "description": "Sender email address.",
                "format": "email"
              },
              "name": {
                "type": "string",
                "description": "Sender display name."
              }
            },
            "additionalProperties": false,
            "required": [
              "email"
            ],
            "description": "Sender object accepted by the MailerSend email API."
          },
          "to": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "description": "Email address for the recipient.",
                  "format": "email"
                },
                "name": {
                  "type": "string",
                  "description": "Display name for the recipient."
                }
              },
              "additionalProperties": false,
              "required": [
                "email"
              ],
              "description": "Recipient object accepted by the MailerSend email API."
            },
            "description": "Primary recipients.",
            "minItems": 1
          },
          "cc": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "description": "Email address for the recipient.",
                  "format": "email"
                },
                "name": {
                  "type": "string",
                  "description": "Display name for the recipient."
                }
              },
              "additionalProperties": false,
              "required": [
                "email"
              ],
              "description": "Recipient object accepted by the MailerSend email API."
            },
            "description": "Carbon copy recipients.",
            "minItems": 1
          },
          "bcc": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "description": "Email address for the recipient.",
                  "format": "email"
                },
                "name": {
                  "type": "string",
                  "description": "Display name for the recipient."
                }
              },
              "additionalProperties": false,
              "required": [
                "email"
              ],
              "description": "Recipient object accepted by the MailerSend email API."
            },
            "description": "Blind carbon copy recipients.",
            "minItems": 1
          },
          "reply_to": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "description": "Sender email address.",
                "format": "email"
              },
              "name": {
                "type": "string",
                "description": "Sender display name."
              }
            },
            "additionalProperties": false,
            "required": [
              "email"
            ],
            "description": "Sender object accepted by the MailerSend email API."
          },
          "subject": {
            "type": "string",
            "minLength": 1,
            "description": "Email subject line."
          },
          "text": {
            "type": "string",
            "description": "Plain-text email body."
          },
          "html": {
            "type": "string",
            "description": "HTML email body."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "description": "Tag attached to the message."
            },
            "description": "Tags attached to the email.",
            "minItems": 1
          },
          "variables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "Object returned by the MailerSend API."
            },
            "description": "Variable substitution payloads accepted by MailerSend."
          },
          "personalization": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "Object returned by the MailerSend API."
            },
            "description": "Per-recipient personalization payloads."
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "content": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Base64-encoded attachment content."
                },
                "filename": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Attachment file name."
                },
                "disposition": {
                  "type": "string",
                  "enum": [
                    "attachment",
                    "inline"
                  ],
                  "description": "Attachment disposition used by MailerSend."
                },
                "id": {
                  "type": "string",
                  "description": "Inline attachment content ID."
                },
                "type": {
                  "type": "string",
                  "description": "Attachment MIME type."
                }
              },
              "additionalProperties": false,
              "required": [
                "content",
                "filename"
              ],
              "description": "Attachment object accepted by the MailerSend email API."
            },
            "description": "Attachments included with the email."
          },
          "send_at": {
            "type": "string",
            "description": "Datetime string that schedules the email for future delivery."
          }
        },
        "additionalProperties": false,
        "required": [
          "from",
          "to",
          "subject"
        ],
        "description": "Request payload for sending a transactional email through MailerSend.",
        "anyOf": [
          {
            "required": [
              "text"
            ]
          },
          {
            "required": [
              "html"
            ]
          }
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
