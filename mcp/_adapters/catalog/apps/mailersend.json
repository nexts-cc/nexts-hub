            "description": "Message ID extracted from the x-message-id response header."
          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Raw JSON response body returned by MailerSend."
          }
        },
        "additionalProperties": false,
