                  {
                    "type": "null"
                  }
                ]
              },
              "updatedAt": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The last update timestamp when returned.",
                    "format": "date-time"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "lastUpdaterUserEmail": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The email of the last updater when returned."
                  },
                  {
                    "type": "null"
