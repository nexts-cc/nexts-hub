                  "boolean",
                  "string",
                  "int",
                  "double"
                ],
                "description": "The ConfigCat Feature Flag or Setting type."
              },
              "value": {
                "anyOf": [
                  {
                    "anyOf": [
                      {
                        "type": "boolean",
                        "description": "A boolean Feature Flag value."
