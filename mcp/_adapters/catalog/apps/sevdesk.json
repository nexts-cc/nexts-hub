            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "The referenced sevdesk contact identifier."
                  },
                  "objectName": {
                    "const": "Contact",
                    "type": "string",
                    "description": "The sevdesk model name for a contact reference."
                  }
                },
                "additionalProperties": false,
                "description": "A sevdesk contact reference object."
