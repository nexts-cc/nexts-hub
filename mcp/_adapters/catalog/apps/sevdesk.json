          "name": {
            "anyOf": [
              {
                "type": "string",
                "description": "The organization name. When set, sevdesk treats the contact as an organization."
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "anyOf": [
              {
                "type": "integer",
