                "type": "string",
                "description": "The Nylas request ID when returned."
              },
              {
                "type": "null"
              }
            ]
          },
          "grant": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "The Nylas grant ID."
              },
              "provider": {
                "type": "string",
