      "inputSchema": {
        "type": "object",
        "properties": {
          "grantId": {
            "type": "string",
            "minLength": 1,
            "description": "The Nylas grant ID to access. Nylas also accepts the grant email address for grant-scoped endpoints."
          },
          "exposeAliases": {
            "type": "boolean",
            "description": "Whether Nylas should include Google or Microsoft email aliases."
