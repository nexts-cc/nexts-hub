          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "The raw Nylas response payload."
          }
        },
        "additionalProperties": false,
        "required": [
          "requestId",
          "grant",
          "raw"
        ],
        "description": "The response returned when getting a Nylas grant."
