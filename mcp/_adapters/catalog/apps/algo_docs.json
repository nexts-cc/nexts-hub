    {
      "id": "algo_docs.upload_document_from_url",
      "service": "algo_docs",
      "name": "upload_document_from_url",
      "description": "Import a publicly accessible document URL into AlgoDocs for an extractor and folder.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "extractorId": {
            "type": "string",
            "minLength": 1,
            "description": "The AlgoDocs resource ID."
          },
          "folderId": {
            "type": "string",
            "minLength": 1,
            "description": "The AlgoDocs resource ID."
          },
          "fileUrl": {
            "type": "string",
            "description": "The publicly accessible document URL that AlgoDocs should fetch.",
            "format": "uri"
          }
        },
        "additionalProperties": false,
        "description": "Input parameters for importing an AlgoDocs document from URL."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "document": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "minimum": 1,
                "description": "The AlgoDocs document ID."
              },
              "fileSize": {
                "type": "integer",
                "description": "The uploaded document file size in bytes."
              },
              "fileMD5CheckSum": {
                "type": "string",
                "description": "The uploaded document MD5 checksum."
              },
              "uploadedAt": {
                "type": "string",
                "description": "The document upload timestamp returned by AlgoDocs."
              }
            },
            "additionalProperties": true,
            "description": "An AlgoDocs imported document."
          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "The raw object returned by AlgoDocs."
          }
        },
        "additionalProperties": false,
        "description": "The AlgoDocs imported document response."
      }
    }
  ]
}
