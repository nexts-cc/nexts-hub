              },
              "height": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "Template height in pixels when available."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "outputFormat": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Configured output format such as `jpg`, `png`, or `pdf`."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "outputExtension": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Configured file extension such as `.jpg` or `.pdf`."
