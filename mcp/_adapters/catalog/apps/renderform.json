                  }
                },
                "additionalProperties": false,
                "description": "RenderForm credit usage summary."
              },
              "uploads": {
                "type": "object",
                "properties": {
                  "used": {
                    "type": "integer",
                    "description": "Current upload storage used in bytes."
                  },
                  "total": {
                    "type": "integer",
                    "description": "Maximum upload storage available in bytes."
