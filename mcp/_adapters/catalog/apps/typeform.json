                  "description": "Variables returned with the response."
                },
                "answers": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": true,
                    "description": "A raw nested object returned by the Typeform API."
                  },
                  "description": "Answers submitted with the response."
                }
              },
              "additionalProperties": true,
              "description": "One Typeform response item."
            },
            "description": "The responses returned for this page."
          },
          "pageCount": {
            "type": "integer",
            "minimum": 0,
            "description": "The total number of available pages."
          },
          "totalItems": {
            "type": "integer",
            "minimum": 0,
            "description": "The total number of matching items."
          }
        },
        "additionalProperties": false,
        "description": "The normalized response list returned by Typeform."
