                },
                "submitted_at": {
                  "type": "string",
                  "description": "When the respondent submitted the form."
                },
                "metadata": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true,
                  "description": "A raw nested object returned by the Typeform API."
                },
                "hidden": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true,
                  "description": "A raw nested object returned by the Typeform API."
                },
                "calculated": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true,
                  "description": "A raw nested object returned by the Typeform API."
                },
                "variables": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": true,
                    "description": "A raw nested object returned by the Typeform API."
