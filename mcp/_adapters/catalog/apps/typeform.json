    {
      "id": "typeform.get_workspace",
      "service": "typeform",
      "name": "get_workspace",
      "description": "Get one Typeform workspace by workspace ID.",
      "requiredScopes": [
        "workspaces:read"
      ],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "minLength": 1,
            "description": "The Typeform workspace ID."
          }
        },
        "additionalProperties": false,
        "description": "Parameters for retrieving one Typeform workspace."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "workspace": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "The Typeform workspace identifier."
              },
              "href": {
                "type": "string",
                "description": "The API URL for this workspace."
              },
              "name": {
                "type": "string",
                "description": "The workspace name."
              },
              "forms": {
                "type": "object",
                "properties": {
                  "href": {
                    "type": "string",
                    "description": "The API URL for the forms collection in this workspace."
                  },
                  "count": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "The number of forms in this workspace."
                  }
                },
                "additionalProperties": true,
                "description": "The forms summary returned for a Typeform workspace."
              },
              "members": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "The full name of the workspace member."
                    },
                    "email": {
                      "type": "string",
                      "description": "The email address of the workspace member."
                    },
                    "role": {
                      "type": "string",
                      "description": "The role assigned to the workspace member."
                    }
                  },
                  "additionalProperties": true,
                  "description": "One workspace member returned by Typeform."
                },
                "description": "The members returned for this workspace."
              }
            },
            "additionalProperties": true,
            "description": "A Typeform workspace object."
          }
        },
        "additionalProperties": false,
        "description": "The normalized single-workspace response returned by Typeform."
      }
    },
    {
      "id": "typeform.list_form_responses",
