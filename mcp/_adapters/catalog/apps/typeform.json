    {
      "id": "typeform.list_forms",
      "service": "typeform",
      "name": "list_forms",
      "description": "List forms available to the authenticated Typeform account.",
      "requiredScopes": [
        "forms:read"
      ],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "Optional page number to retrieve."
          },
          "search": {
            "type": "string",
            "minLength": 1,
            "description": "Optional search query used to filter forms."
          },
          "sortBy": {
            "type": "string",
            "enum": [
              "created_at",
              "last_updated_at"
            ],
            "description": "Field used by Typeform to sort forms."
          },
          "orderBy": {
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ],
            "description": "Sort order used by Typeform."
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "description": "Optional page size for forms."
          },
          "workspaceId": {
            "type": "string",
            "minLength": 1,
            "description": "Optional workspace ID used to filter forms."
          }
        },
        "additionalProperties": false,
        "description": "Parameters for listing Typeform forms."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The Typeform form identifier."
                },
                "title": {
                  "type": "string",
                  "description": "The title of the form."
                },
                "theme": {
                  "type": "object",
                  "properties": {
                    "href": {
                      "type": "string",
                      "description": "The API URL for the theme used by this form."
                    }
                  },
                  "additionalProperties": true,
                  "description": "The Typeform theme reference returned on a form."
                },
                "_links": {
                  "type": "object",
                  "properties": {
                    "self": {
                      "type": "object",
                      "properties": {
                        "href": {
                          "type": "string",
                          "description": "The API URL for the current form resource."
                        }
                      },
                      "additionalProperties": true,
                      "description": "A self link returned by Typeform."
                    },
                    "display": {
                      "type": "string",
                      "description": "The public URL used to display the form."
                    },
                    "responses": {
                      "type": "string",
                      "description": "The API URL used to retrieve responses for the form."
                    }
                  },
                  "additionalProperties": true,
                  "description": "The related links returned on a Typeform form."
                },
                "settings": {
                  "type": "object",
                  "properties": {
                    "is_public": {
                      "type": "boolean",
                      "description": "Whether the form is publicly accessible."
                    }
                  },
                  "additionalProperties": true,
                  "description": "A subset of Typeform settings returned on a form summary."
                },
                "workspace": {
                  "type": "object",
                  "properties": {
                    "href": {
                      "type": "string",
                      "description": "The API URL for the workspace that owns the form."
                    }
                  },
                  "additionalProperties": true,
                  "description": "The workspace reference returned on a Typeform form."
                },
                "created_at": {
                  "type": "string",
                  "description": "The timestamp when the form was created."
                },
                "last_updated_at": {
                  "type": "string",
                  "description": "The timestamp when the form was last updated."
                }
              },
              "additionalProperties": true,
              "description": "A Typeform form summary returned by the list-forms endpoint."
            },
            "description": "The forms returned for this page."
          },
          "pageCount": {
            "type": "integer",
            "minimum": 0,
            "description": "The total number of available pages."
          },
          "totalItems": {
            "type": "integer",
            "minimum": 0,
            "description": "The total number of matching items."
          }
        },
        "additionalProperties": false,
        "description": "The normalized paginated form list returned by Typeform."
      }
    },
