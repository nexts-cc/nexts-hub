{
  "service": "stay_ai",
  "displayName": "Stay AI",
  "categories": [
    "Marketing",
    "Productivity"
  ],
  "authTypes": [
    "api_key"
  ],
  "auth": [
    {
      "type": "api_key",
      "label": "API Key",
      "placeholder": "stay_ai_api_key",
      "description": "Stay AI API key sent with the X-RETEXTION-ACCESS-TOKEN header. Use the API key described in the Stay AI Open API authentication guide: https://docs.stay.ai/recipes/authenticate-open-api"
    }
  ],
  "homepageUrl": "https://stay.ai",
  "actions": [
    {
      "id": "stay_ai.get_account_settings",
      "service": "stay_ai",
      "name": "get_account_settings",
      "description": "Retrieve account-level Stay AI settings for the current API key.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string",
            "minLength": 1,
            "description": "The Stay AI account ID whose settings should be retrieved."
          }
        },
        "additionalProperties": false,
        "description": "Filters for retrieving Stay AI account settings."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "settings": {
            "type": "object",
            "properties": {
              "emailSenderName": {
                "type": "string",
                "description": "Email sender name configured for the account."
              },
              "emailSenderAddress": {
                "type": "string",
                "description": "Email sender address configured for the account."
              },
              "emailReplyName": {
                "type": "string",
                "description": "Email reply-to name configured for the account."
              },
              "emailReplyAddress": {
                "type": "string",
                "description": "Email reply-to address configured for the account."
              },
              "notificationDelay": {
                "type": "integer",
                "description": "Notification delay setting returned by Stay AI."
              },
              "enableMultipleDiscounts": {
                "type": "boolean",
                "description": "Whether the account allows multiple discounts."
              }
            },
            "additionalProperties": true,
            "description": "Stay AI account settings."
          }
        },
        "additionalProperties": false,
        "required": [
          "settings"
        ],
        "description": "Stay AI account settings response."
      }
    },
    {
      "id": "stay_ai.get_subscription",
      "service": "stay_ai",
      "name": "get_subscription",
      "description": "Retrieve a Stay AI subscription by Shopify or internal subscription ID.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string",
            "minLength": 1,
            "description": "Shopify or internal subscription ID."
          }
        },
        "additionalProperties": false,
        "required": [
          "subscriptionId"
        ],
        "description": "Identifier for retrieving one Stay AI subscription."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "subscription": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Stay AI internal subscription record ID."
              },
              "subscriptionId": {
                "type": "string",
                "description": "Shopify subscription contract global ID."
              },
              "customerId": {
                "type": "string",
                "description": "Shopify customer ID."
              },
              "emailAddress": {
                "type": "string",
                "description": "Customer email address."
              },
              "createdAt": {
                "type": "string",
                "description": "Timestamp when the subscription was created."
              },
              "updatedAt": {
                "type": "string",
                "description": "Timestamp when the subscription was last updated."
              },
              "nextBillingDate": {
                "type": "string",
                "description": "Timestamp for the next billing date."
              },
              "status": {
                "type": "string",
                "description": "Subscription status returned by Stay AI."
              },
              "currency": {
                "type": "string",
                "description": "Currency code for the subscription."
              },
              "price": {
                "type": "number",
                "description": "Subscription price returned by Stay AI."
              },
              "lineItems": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true,
                  "description": "Stay AI subscription line item."
                },
                "description": "Subscription line items returned by Stay AI."
              }
            },
            "additionalProperties": true,
            "description": "Stay AI subscription object."
          }
        },
        "additionalProperties": false,
        "required": [
          "subscription"
        ],
        "description": "Stay AI subscription response."
      }
    },
    {
      "id": "stay_ai.list_orders",
      "service": "stay_ai",
      "name": "list_orders",
      "description": "Query Stay AI orders with documented filters, sorting, and pagination.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "createdAtMin": {
            "type": "integer",
            "description": "Minimum created timestamp in milliseconds."
          },
          "createdAtMax": {
            "type": "integer",
            "description": "Maximum created timestamp in milliseconds."
          },
          "updatedAtMin": {
            "type": "integer",
            "description": "Minimum updated timestamp in milliseconds."
          },
          "updatedAtMax": {
            "type": "integer",
            "description": "Maximum updated timestamp in milliseconds."
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "Page number to request. Stay AI pages start from 1."
          },
          "pageSize": {
            "type": "integer",
            "minimum": 5,
            "maximum": 100,
            "description": "Number of records per page. Stay AI documents 5 to 100."
          },
          "sortBy": {
            "type": "string",
            "enum": [
              "createdAt",
              "updatedAt"
            ],
            "description": "Field used to sort Stay AI records."
          },
          "sortDirection": {
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ],
            "description": "Sort direction accepted by Stay AI."
          }
        },
        "additionalProperties": false,
        "description": "Filters, sorting, and pagination for querying Stay AI orders."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number",
            "description": "Total number of matching orders."
          },
          "orders": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "orderId": {
                  "type": "string",
                  "description": "Shopify order global ID."
                },
                "orderName": {
                  "type": "string",
                  "description": "Shopify order display name."
                },
                "customerId": {
                  "type": "string",
                  "description": "Shopify customer ID."
                },
                "subscriptionId": {
                  "type": "string",
                  "description": "Shopify subscription contract global ID."
                },
                "createdAt": {
                  "type": "string",
                  "description": "Timestamp when the order was created."
                },
                "updatedAt": {
                  "type": "string",
                  "description": "Timestamp when the order was last updated."
                },
                "fulfillmentStatus": {
                  "type": "string",
                  "description": "Order fulfillment status."
                },
                "currency": {
                  "type": "string",
                  "description": "Currency code for the order."
                },
                "totalPrice": {
                  "type": "number",
                  "description": "Total order price returned by Stay AI."
                },
                "lineItems": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": true,
                    "description": "Stay AI order line item."
                  },
                  "description": "Order line items returned by Stay AI."
                }
              },
              "additionalProperties": true,
              "description": "Stay AI order object."
            },
            "description": "Orders returned by Stay AI."
          }
        },
        "additionalProperties": false,
        "required": [
          "total",
          "orders"
        ],
        "description": "Stay AI order list response."
      }
    },
    {
      "id": "stay_ai.list_subscriptions",
