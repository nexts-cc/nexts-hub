              },
              "customerName": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The caller or customer name."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "customerPhoneNumber": {
                "anyOf": [
                  {
