              },
              "numberOfSeats": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "Number of seats available on the account."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "currentRiskScore": {
                "anyOf": [
                  {
                    "type": "number",
                    "description": "Current account risk score."
                  },
                  {
                    "type": "null"
                  }
