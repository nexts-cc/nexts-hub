      "id": "knowbe4.get_account",
      "service": "knowbe4",
      "name": "get_account",
      "description": "Get KnowBe4 account and subscription data from the Reporting API.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {},
