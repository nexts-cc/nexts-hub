  "homepageUrl": "https://databar.ai/",
  "actions": [
    {
      "id": "databar_ai.create_table",
      "service": "databar_ai",
      "name": "create_table",
      "description": "Create a Databar table with optional columns and empty rows.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "The table name."
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "The initial human-readable column names.",
            "minItems": 1
          },
          "rows": {
            "type": "integer",
            "minimum": 0,
            "description": "The number of empty rows Databar should create."
          }
        },
        "additionalProperties": false,
        "description": "The input payload for creating a Databar table."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "table": {
            "type": "object",
            "properties": {
              "identifier": {
                "type": "string",
                "description": "The table identifier returned by Databar."
              },
              "name": {
                "type": "string",
                "description": "The table name."
              },
              "created_at": {
                "type": "string",
                "description": "The table creation timestamp."
              },
              "updated_at": {
                "type": "string",
                "description": "The table update timestamp."
              },
              "workspace_identifier": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The workspace identifier associated with the table when present."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "table_url": {
                "type": "string",
                "description": "The Databar web URL for the table."
              },
              "raw": {
                "type": "object",
                "properties": {},
                "additionalProperties": true,
                "description": "The object returned by Databar."
              }
            },
            "additionalProperties": true,
            "description": "A Databar table."
          }
        },
        "additionalProperties": false,
        "required": [
          "table"
        ],
        "description": "Action output."
      }
    },
