{
  "service": "digital_ocean",
  "displayName": "DigitalOcean",
  "categories": [
    "Developer Tools"
  ],
  "authTypes": [
    "api_key"
  ],
  "auth": [
    {
      "type": "api_key",
      "label": "Personal Access Token",
      "placeholder": "dop_v1_...",
      "description": "DigitalOcean personal access token used with the Authorization Bearer header. Create one from the DigitalOcean API Tokens page.",
      "extraFields": []
    }
  ],
  "homepageUrl": "https://www.digitalocean.com",
  "actions": [
    {
      "id": "digital_ocean.get_account",
      "service": "digital_ocean",
      "name": "get_account",
      "description": "Retrieve the current DigitalOcean account profile and team context for the connected token.",
      "requiredScopes": [
        "account:read"
      ],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false,
        "description": "No input is required."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "account": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "description": "Unique identifier of the account."
              },
              "email": {
                "type": "string",
                "description": "Email address of the current account.",
                "format": "email"
              },
              "name": {
                "type": "string",
                "description": "Display name of the current account, when present."
              },
              "status": {
                "type": "string",
                "enum": [
                  "active",
                  "warning",
                  "locked"
                ],
                "description": "Current account status."
              }
            },
            "additionalProperties": true,
            "description": "DigitalOcean account."
          }
        },
        "additionalProperties": false,
        "required": [
          "account"
        ],
        "description": "Current DigitalOcean account."
      }
    },
    {
      "id": "digital_ocean.get_droplet",
      "service": "digital_ocean",
      "name": "get_droplet",
      "description": "Retrieve one DigitalOcean Droplet by numeric droplet ID.",
      "requiredScopes": [
        "droplet:read"
      ],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "dropletId": {
            "type": "integer",
            "minimum": 1,
            "description": "Numeric identifier of the Droplet."
          }
        },
        "additionalProperties": false,
        "required": [
          "dropletId"
        ],
        "description": "Input for retrieving a DigitalOcean Droplet."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "droplet": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "description": "Numeric identifier of the Droplet."
              },
              "name": {
                "type": "string",
                "description": "Droplet name."
              },
              "status": {
                "type": "string",
                "description": "Current Droplet status."
              },
              "created_at": {
                "type": "string",
                "description": "Timestamp when the Droplet was created.",
                "format": "date-time"
              }
            },
            "additionalProperties": true,
            "description": "DigitalOcean Droplet."
          }
        },
        "additionalProperties": false,
        "required": [
          "droplet"
        ],
        "description": "Single DigitalOcean Droplet."
      }
    },
