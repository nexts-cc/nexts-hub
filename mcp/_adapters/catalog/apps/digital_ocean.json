      "id": "digital_ocean.list_domain_records",
      "service": "digital_ocean",
      "name": "list_domain_records",
      "description": "List DNS records for one DigitalOcean domain, optionally filtered by record name or type.",
      "requiredScopes": [
        "domain:read"
      ],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "domainName": {
            "type": "string",
            "minLength": 1,
            "description": "The exact domain name whose DNS records should be listed."
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "Page number to return."
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "description": "Maximum number of results to return per page."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Only return records whose fully qualified name exactly matches this value."
          },
          "type": {
            "type": "string",
            "enum": [
              "A",
              "AAAA",
              "CAA",
              "CNAME",
              "MX",
              "NS",
              "TXT",
              "SRV",
              "SOA"
            ],
            "description": "Only return DNS records of this record type."
          }
        },
        "additionalProperties": false,
        "required": [
          "domainName"
        ],
        "description": "Input for listing DigitalOcean domain records."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "domainRecords": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "A raw DigitalOcean object."
            },
            "description": "Domain records returned for the current page."
          },
          "links": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Pagination links returned by DigitalOcean, when present."
          },
          "meta": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Pagination metadata returned by DigitalOcean, when present."
          }
        },
        "additionalProperties": false,
        "required": [
          "domainRecords"
        ],
        "description": "Paginated DigitalOcean domainRecords list."
      }
