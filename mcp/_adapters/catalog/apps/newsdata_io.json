    {
      "id": "newsdata_io.get_latest_news",
      "service": "newsdata_io",
      "name": "get_latest_news",
      "description": "Retrieve the latest and breaking news from NewsData.io with optional filters.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated NewsData.io article IDs to fetch."
          },
          "q": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "description": "Keyword or phrase search across article title, content, URL, and metadata."
          },
          "qInTitle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "description": "Keyword or phrase search restricted to article titles."
          },
          "qInMeta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "description": "Keyword or phrase search restricted to article title, URL, and metadata."
          },
          "country": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated country codes, up to 5 values."
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated categories to include, up to 5 values."
          },
          "excludecategory": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated categories to exclude, up to 5 values."
          },
          "language": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated language codes, up to 5 values."
          },
          "domain": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated source domain names, up to 5 values."
          },
          "domainurl": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated source domain URLs, up to 5 values."
          },
          "excludedomain": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated source domain URLs to exclude."
          },
          "excludefield": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated response fields to exclude."
          },
          "prioritydomain": {
            "type": "string",
            "enum": [
              "top",
              "medium",
              "low"
            ],
            "description": "News source reputation tier filter."
          },
          "timezone": {
            "type": "string",
            "minLength": 1,
            "description": "Timezone filter such as America/New_York or Europe/Berlin."
          },
          "full_content": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "Boolean-like NewsData.io flag, where 1 means yes and 0 means no."
          },
          "image": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "Boolean-like NewsData.io flag, where 1 means yes and 0 means no."
          },
          "video": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "Boolean-like NewsData.io flag, where 1 means yes and 0 means no."
          },
          "size": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "description": "Number of articles to request, from 1 to 50."
          },
          "page": {
            "type": "string",
            "minLength": 1,
            "description": "Pagination cursor returned as nextPage from a previous response."
          },
          "timeframe": {
            "type": "string",
            "minLength": 1,
            "description": "Latest-news time window in hours, 1 to 48, or minutes such as 15m."
          },
          "tag": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated AI-classified tags, up to 5 values."
          },
          "sentiment": {
            "type": "string",
            "enum": [
              "positive",
              "negative",
              "neutral"
            ],
            "description": "AI sentiment label used to filter articles."
          },
          "region": {
            "type": "string",
            "minLength": 1,
            "description": "Comma-separated geographic regions on supported plans."
          },
          "removeduplicate": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "Boolean-like NewsData.io flag, where 1 means yes and 0 means no."
          }
        },
        "additionalProperties": false,
        "description": "Input parameters for retrieving latest NewsData.io articles."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Top-level request status returned by NewsData.io."
          },
          "totalResults": {
            "type": "integer",
            "description": "Total number of matching articles available."
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "A NewsData.io article object."
            },
            "description": "Articles returned for this request."
          },
          "nextPage": {
            "type": "string",
            "description": "Cursor token to request the next page."
          }
        },
        "additionalProperties": true,
        "required": [
          "status",
          "results"
        ],
        "description": "NewsData.io article collection response."
      }
    },
