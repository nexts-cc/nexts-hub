    {
      "id": "quickbase.get_table_fields",
      "service": "quickbase",
      "name": "get_table_fields",
      "description": "List fields in a Quickbase table.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "tableId": {
            "type": "string",
            "minLength": 1,
            "description": "Quickbase table identifier."
          },
          "includeFieldPerms": {
            "type": "boolean",
            "description": "Whether to include field permission metadata."
          }
        },
        "additionalProperties": false,
        "required": [
          "tableId"
        ],
        "description": "Input parameters for listing fields in a Quickbase table."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "Object returned by Quickbase."
            },
            "description": "Fields returned by Quickbase."
          }
        },
        "additionalProperties": false,
        "description": "Quickbase field list response."
      }
    },
    {
      "id": "quickbase.list_app_tables",
      "service": "quickbase",
      "name": "list_app_tables",
      "description": "List tables in a Quickbase app.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "appId": {
            "type": "string",
            "minLength": 1,
            "description": "Quickbase app identifier."
          }
        },
        "additionalProperties": false,
        "description": "Input parameters for listing tables in a Quickbase app."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "tables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
