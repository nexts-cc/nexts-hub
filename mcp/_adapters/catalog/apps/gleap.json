                "type": "string",
                "description": "Contact email address."
              },
              "name": {
                "type": "string",
                "description": "Contact display name."
              },
              "phone": {
                "type": "string",
                "description": "Contact phone number."
              },
              "avatar": {
                "type": "string",
                "description": "Contact avatar URL."
              },
              "companyId": {
                "type": "string",
                "description": "Company ID associated with the contact."
              },
              "companyName": {
                "type": "string",
