          },
          "blocked": {
            "type": "boolean",
            "description": "Whether the contact is blocked."
          },
          "unsubscribed": {
            "type": "boolean",
            "description": "Whether the contact is unsubscribed."
          },
          "customData": {
            "type": "object",
            "properties": {},
