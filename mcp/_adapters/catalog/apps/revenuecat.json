      "id": "revenuecat.get_revenue_metric",
      "service": "revenuecat",
      "name": "get_revenue_metric",
      "description": "Retrieve total RevenueCat project revenue for an inclusive date range.",
      "requiredScopes": [
        "charts_metrics:overview:read"
      ],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectId": {
