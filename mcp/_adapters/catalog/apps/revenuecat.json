        "type": "object",
        "properties": {
          "metric": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "RevenueCat revenue metric data."
          }
        },
        "additionalProperties": false,
        "description": "RevenueCat revenue metric response."
      }
