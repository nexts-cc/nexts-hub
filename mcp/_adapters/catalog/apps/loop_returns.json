    {
      "id": "loop_returns.list_returns",
      "service": "loop_returns",
      "name": "list_returns",
      "description": "List Loop Returns returns created or updated within an optional timeframe.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "description": "The start date and time for the returns list."
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "description": "The end date and time for the returns list."
          },
          "filter": {
            "type": "string",
            "enum": [
              "created_at",
              "updated_at"
            ],
            "description": "The date field Loop Returns should use to filter results."
          },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "cancelled",
              "expired",
              "review"
            ],
            "description": "The return state to filter by."
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1,
            "maximum": 750,
            "description": "The number of returns to return per page."
          },
          "cursor": {
            "type": "string",
            "minLength": 1,
            "description": "The Loop Returns cursor identifying the page to return."
          }
        },
        "additionalProperties": false,
        "description": "Input for listing Loop Returns returns."
