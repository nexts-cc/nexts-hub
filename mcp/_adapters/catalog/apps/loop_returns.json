                    {
                      "type": "string",
                      "description": "The current return state."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "createdAt": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The date and time when the return was created."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "updatedAt": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The date and time when the return was last updated."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "orderId": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The Loop Returns order identifier."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "orderName": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The order name."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "providerOrderId": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The provider order identifier, such as a Shopify order ID."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "customer": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The customer email address returned by Loop Returns."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "currency": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The return currency code."
