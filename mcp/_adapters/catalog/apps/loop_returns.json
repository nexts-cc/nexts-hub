    {
      "id": "loop_returns.get_destination",
      "service": "loop_returns",
      "name": "get_destination",
      "description": "Get one Loop Returns destination by ID.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "destinationId": {
            "type": "integer",
            "minimum": 1,
            "description": "The Loop Returns destination ID."
          }
        },
        "additionalProperties": false,
        "description": "Input for retrieving one Loop Returns destination."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "destination": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "description": "The Loop Returns destination identifier."
              },
              "type": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The destination type returned by Loop Returns."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "name": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The destination name."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "enabled": {
                "anyOf": [
                  {
                    "type": "boolean",
                    "description": "Whether the destination is enabled."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "providerLocationId": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "The commerce-platform location identifier linked to this destination."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "address": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "address1": {
                        "anyOf": [
                          {
                            "type": "string",
                            "description": "The street address of the destination."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "address2": {
                        "anyOf": [
                          {
                            "type": "string",
                            "description": "The secondary address details of the destination."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "city": {
                        "anyOf": [
                          {
                            "type": "string",
                            "description": "The destination city."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "state": {
                        "anyOf": [
                          {
                            "type": "string",
                            "description": "The destination state or region."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "zip": {
                        "anyOf": [
                          {
                            "type": "string",
                            "description": "The destination postal code."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "country": {
                        "anyOf": [
                          {
                            "type": "string",
                            "description": "The destination country name."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "countryCode": {
                        "anyOf": [
                          {
                            "type": "string",
                            "description": "The destination ISO country code."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      }
                    },
                    "additionalProperties": false,
                    "description": "A Loop Returns destination address."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "raw": {
                "type": "object",
                "additionalProperties": true,
                "description": "The raw object returned by Loop Returns."
              }
            },
            "additionalProperties": false,
            "description": "A normalized Loop Returns destination."
          }
        },
        "additionalProperties": false,
        "description": "The response returned when getting a Loop Returns destination."
      }
    },
