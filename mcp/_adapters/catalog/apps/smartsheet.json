                "indent": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 1,
                  "description": "The indent operation amount. Smartsheet expects 1."
                },
                "outdent": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 1,
                  "description": "The outdent operation amount. Smartsheet expects 1."
                },
                "expanded": {
                  "type": "boolean",
                  "description": "Whether the row is expanded."
                },
                "locked": {
