        "type": "object",
        "properties": {
          "formId": {
            "type": "string",
            "minLength": 1,
            "description": "The Forminit form ID whose submissions should be listed."
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "The page number to request."
          },
          "size": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "The page size to request. Forminit documents a range of 1 to 100."
          },
          "query": {
            "type": "string",
            "minLength": 1,
            "description": "Search keyword used to filter submissions."
          },
          "files": {
            "type": "boolean",
            "description": "Whether to include file attachment metadata in the response."
          },
          "timezone": {
            "type": "string",
            "minLength": 1,
            "description": "IANA timezone name used to format returned dates."
