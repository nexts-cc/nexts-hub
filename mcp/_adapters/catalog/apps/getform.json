                              },
                              "firstName": {
                                "type": "string",
                                "description": "Submitter first name."
                              },
                              "lastName": {
                                "type": "string",
                                "description": "Submitter last name."
                              },
                              "fullName": {
                                "type": "string",
                                "description": "Submitter full name."
                              },
                              "phone": {
                                "type": "string",
