    {
      "id": "opsgenie.create_alert",
      "service": "opsgenie",
      "name": "create_alert",
      "description": "Create an Opsgenie alert and return the asynchronous request ID.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 130,
            "description": "Message of the alert."
          },
          "alias": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "description": "Client-defined identifier for alert de-duplication."
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15000,
            "description": "Detailed alert description."
          },
          "responders": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "team",
                    "user",
                    "escalation",
                    "schedule"
                  ],
                  "description": "Opsgenie responder type."
                },
                "id": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opsgenie responder ID."
                },
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opsgenie responder name."
                },
                "username": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opsgenie user responder username."
                }
              },
              "additionalProperties": true,
              "required": [
                "type"
              ],
              "description": "Opsgenie responder target. Provide id, name, or username according to the responder type."
            },
            "description": "Teams, users, escalations, or schedules to notify.",
            "minItems": 1,
            "maxItems": 50
          },
          "visibleTo": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "team",
                    "user"
                  ],
                  "description": "Opsgenie visibility target type."
                },
                "id": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opsgenie visibility target ID."
                },
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opsgenie team name."
                },
                "username": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opsgenie user username."
                }
              },
              "additionalProperties": true,
              "required": [
                "type"
              ],
              "description": "Opsgenie visibility target. Provide id, name, or username according to the target type."
            },
            "description": "Teams or users that can view the alert.",
            "minItems": 1,
            "maxItems": 50
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "description": "One string value."
            },
            "description": "Custom actions available for the alert.",
            "minItems": 1,
            "maxItems": 10
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "description": "One string value."
            },
            "description": "Tags to add to the alert.",
            "minItems": 1,
            "maxItems": 20
          },
          "details": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "description": "One Opsgenie alert detail value."
            },
            "description": "Opsgenie alert details as key-value string properties."
          },
          "entity": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "description": "Entity related to the alert."
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Alert source."
          },
          "priority": {
            "type": "string",
            "enum": [
              "P1",
              "P2",
              "P3",
              "P4",
              "P5"
            ],
            "description": "Opsgenie alert priority."
          },
          "user": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "note": {
            "type": "string",
            "minLength": 1,
            "maxLength": 25000,
            "description": "Additional note added while creating the alert."
          }
        },
        "additionalProperties": false,
        "required": [
          "message"
        ],
        "description": "Opsgenie alert creation request."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "description": "Opsgenie request acceptance message."
          },
          "took": {
            "type": "number",
            "description": "Time Opsgenie spent accepting the request."
          },
          "requestId": {
            "type": "string",
            "description": "Opsgenie request ID for polling request status."
          }
        },
        "additionalProperties": false,
        "description": "Opsgenie asynchronous request response."
      },
      "followUpActions": [
        "opsgenie.get_request_status"
      ],
      "asyncLifecycle": {
        "startActionId": "opsgenie.create_alert",
        "statusActionId": "opsgenie.get_request_status"
      }
    },
    {
      "id": "opsgenie.get_alert",
      "service": "opsgenie",
