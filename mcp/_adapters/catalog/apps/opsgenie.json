{
  "service": "opsgenie",
  "displayName": "Opsgenie",
  "categories": [
    "Developer Tools"
  ],
  "authTypes": [
    "api_key"
  ],
  "auth": [
    {
      "type": "api_key",
      "label": "API Key",
      "placeholder": "OPSGENIE_API_KEY",
      "description": "Opsgenie API Integration key sent with the Authorization GenieKey header. Create an API Integration and copy its API key from Opsgenie Settings > Integrations: https://docs.opsgenie.com/docs/alert-api",
      "extraFields": [
        {
          "key": "environment",
          "label": "Environment",
          "inputType": "text",
          "required": true,
          "secret": false,
          "placeholder": "us",
          "description": "Opsgenie API region for this key. Use us for https://api.opsgenie.com or eu for https://api.eu.opsgenie.com."
        }
      ]
    }
  ],
  "homepageUrl": "https://www.atlassian.com/software/opsgenie",
  "actions": [
    {
      "id": "opsgenie.acknowledge_alert",
      "service": "opsgenie",
      "name": "acknowledge_alert",
      "description": "Acknowledge an Opsgenie alert and return the asynchronous request ID.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "minLength": 1,
            "description": "Opsgenie alert identifier."
          },
          "identifierType": {
            "type": "string",
            "enum": [
              "id",
              "tiny",
              "alias"
            ],
            "description": "Type of Opsgenie alert identifier."
          },
          "user": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "minLength": 1,
            "maxLength": 25000,
            "description": "Additional alert note."
          }
        },
        "additionalProperties": false,
        "required": [
          "identifier"
        ],
        "description": "Opsgenie alert mutation target."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "description": "Opsgenie request acceptance message."
          },
          "took": {
            "type": "number",
            "description": "Time Opsgenie spent accepting the request."
          },
          "requestId": {
            "type": "string",
            "description": "Opsgenie request ID for polling request status."
          }
        },
        "additionalProperties": false,
        "description": "Opsgenie asynchronous request response."
      },
      "followUpActions": [
        "opsgenie.get_request_status"
      ],
      "asyncLifecycle": {
        "startActionId": "opsgenie.acknowledge_alert",
        "statusActionId": "opsgenie.get_request_status"
      }
    },
