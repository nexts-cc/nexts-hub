        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "minLength": 1,
            "description": "Opsgenie alert identifier."
          },
          "identifierType": {
            "type": "string",
            "enum": [
              "id",
              "tiny",
              "alias"
            ],
            "description": "Type of Opsgenie alert identifier."
          }
        },
        "additionalProperties": false,
        "required": [
          "identifier"
        ],
        "description": "Opsgenie alert lookup request."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "alert": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Opsgenie alert record."
          },
          "requestId": {
            "type": "string",
            "description": "Opsgenie request ID."
          }
        },
        "additionalProperties": false,
        "description": "Opsgenie alert lookup response."
      }
    },
