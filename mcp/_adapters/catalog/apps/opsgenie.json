    {
      "id": "opsgenie.get_request_status",
      "service": "opsgenie",
      "name": "get_request_status",
      "description": "Get processing status for an Opsgenie asynchronous alert request.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "minLength": 1,
            "description": "Opsgenie asynchronous request ID."
          }
        },
        "additionalProperties": false,
        "required": [
          "requestId"
        ],
        "description": "Opsgenie request status lookup."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "success": {
                "type": "boolean",
                "description": "Whether the asynchronous request status call succeeded."
              },
              "action": {
                "type": "string",
                "description": "Opsgenie asynchronous action name."
              },
              "processedAt": {
                "type": "string",
                "description": "Date and time when Opsgenie processed the request."
              },
              "integrationId": {
                "type": "string",
                "description": "Opsgenie integration ID."
              },
              "isSuccess": {
                "type": "boolean",
                "description": "Whether the original asynchronous request succeeded."
              },
              "status": {
                "type": "string",
                "description": "Human-readable processing status."
              },
              "alertId": {
                "type": "string",
                "description": "Alert ID affected by the request, when available."
              },
              "alias": {
                "type": "string",
                "description": "Alert alias affected by the request, when available."
              }
            },
            "additionalProperties": true,
            "description": "Opsgenie request status data."
          },
          "took": {
            "type": "number",
            "description": "Time Opsgenie spent returning the request status."
          },
          "requestId": {
            "type": "string",
            "description": "Opsgenie request ID for this status lookup."
          }
        },
        "additionalProperties": false,
        "description": "Opsgenie request status response."
      }
    },
    {
      "id": "opsgenie.list_alerts",
      "service": "opsgenie",
      "name": "list_alerts",
      "description": "List Opsgenie alerts with query, saved-search, sorting, and paging filters.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "description": "Opsgenie alert search query."
          },
          "searchIdentifier": {
            "type": "string",
            "minLength": 1,
            "description": "Opsgenie saved-search identifier."
          },
          "searchIdentifierType": {
            "type": "string",
            "enum": [
              "id",
              "name"
            ],
            "description": "Type of Opsgenie saved-search identifier."
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "description": "Start index of the result set."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Maximum number of alerts to return."
          },
          "sort": {
            "type": "string",
            "minLength": 1,
            "description": "Alert field to sort by."
          },
          "order": {
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ],
            "description": "Sort direction for the Opsgenie result set."
          }
        },
        "additionalProperties": false,
        "description": "Opsgenie alert list filters."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "alerts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
              "description": "Opsgenie alert record."
            },
            "description": "Opsgenie alerts returned by the query."
          },
          "pagination": {
            "type": "object",
            "properties": {
              "offset": {
                "type": "integer",
                "description": "Start index of this result page."
              },
              "limit": {
                "type": "integer",
                "description": "Maximum number of records requested."
              },
              "count": {
                "type": "integer",
                "description": "Number of records returned in this page."
              }
            },
            "additionalProperties": false,
            "description": "Opsgenie pagination metadata."
          },
          "requestId": {
            "type": "string",
            "description": "Opsgenie request ID."
          }
        },
        "additionalProperties": false,
        "description": "Opsgenie alert list response."
      }
    }
  ]
