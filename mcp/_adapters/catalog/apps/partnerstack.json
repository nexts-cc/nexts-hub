        "type": "object",
        "properties": {
          "customerKey": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "External customer key to assign to the customer."
          },
          "partnerKey": {
            "type": "string",
            "minLength": 1,
            "description": "Partner key responsible for the customer."
          },
          "email": {
            "type": "string",
