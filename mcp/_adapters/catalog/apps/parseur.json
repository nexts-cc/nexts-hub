  ],
  "authTypes": [
    "api_key"
  ],
  "auth": [
    {
      "type": "api_key",
      "label": "API Key",
      "placeholder": "PARSEUR_API_KEY",
      "description": "Parseur API key sent with the Authorization header. Create or view keys at https://app.parseur.com/account/api-keys.",
      "extraFields": []
    }
  ],
  "homepageUrl": "https://parseur.com",
  "actions": [
    {
      "id": "parseur.get_document",
      "service": "parseur",
      "name": "get_document",
      "description": "Retrieve detailed metadata and parsed result for one Parseur document.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "description": "Parseur document identifier."
          }
        },
        "additionalProperties": false,
        "description": "Input parameters for retrieving a Parseur document."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "document": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "description": "Parseur document identifier."
              },
              "name": {
                "type": "string",
                "description": "Document name returned by Parseur."
              },
              "parser": {
                "type": "integer",
                "description": "Parseur mailbox identifier that owns the document."
              },
              "status": {
                "type": "string",
                "enum": [
                  "INCOMING",
                  "ANALYZING",
                  "PROGRESS",
                  "PARSEDOK",
                  "PARSEDKO",
                  "QUOTAEXC",
                  "SKIPPED",
                  "SPLIT",
                  "EXPORTKO",
                  "TRANSKO",
                  "INVALID"
                ],
                "description": "Parseur document processing status."
              },
              "status_source": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Source that produced the document status."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "received": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Timestamp when Parseur received the document.",
                    "format": "date-time"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "processed": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Timestamp when Parseur processed the document.",
                    "format": "date-time"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "original_document_url": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "URL for the original document.",
                    "format": "uri"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "json_download_url": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "URL for the parsed JSON result.",
                    "format": "uri"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "csv_download_url": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "URL for the parsed CSV result.",
                    "format": "uri"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "xls_download_url": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "URL for the parsed XLS result.",
                    "format": "uri"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "raw": {
                "type": "object",
                "properties": {},
                "additionalProperties": true,
                "description": "Raw object returned by Parseur."
              },
              "result": {
                "anyOf": [
                  {
                    "description": "Parsed result returned by Parseur."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "content": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Text content returned by Parseur when available."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "next_id": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "Next document identifier when available."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "prev_id": {
                "anyOf": [
                  {
                    "type": "integer",
                    "description": "Previous document identifier when available."
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "additionalProperties": false,
            "description": "Detailed Parseur document metadata and parsed data."
          }
        },
        "additionalProperties": false,
        "description": "Parseur document details."
      }
    },
