    {
      "id": "listennotes.search",
      "service": "listennotes",
      "name": "search",
      "description": "Search Listen Notes podcasts or episodes by keyword.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "minLength": 1,
            "description": "The search keywords to send to Listen Notes."
          },
          "type": {
            "type": "string",
            "enum": [
              "episode",
              "podcast"
            ],
            "description": "The supported Listen Notes search result type."
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "description": "The search offset for pagination."
          },
          "region": {
            "type": "string",
            "minLength": 1,
            "description": "The region code used to limit search results."
          },
          "language": {
            "type": "string",
            "minLength": 1,
            "description": "The language label used to limit search results."
          },
          "genreIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1,
              "description": "One Listen Notes genre identifier."
            },
            "description": "The Listen Notes genre identifiers used to filter results.",
            "minItems": 1
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "The number of search results to return per page."
          },
          "safeMode": {
            "type": "boolean",
            "description": "Whether to exclude explicit podcasts or episodes."
          },
          "sortByDate": {
            "type": "boolean",
            "description": "Whether to sort search results by publication date instead of relevance."
          },
          "onlyIn": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "title",
                "description",
                "author",
                "audio"
              ],
              "description": "One Listen Notes searchable field."
            },
            "description": "The specific upstream fields to search within.",
            "minItems": 1
          },
          "uniquePodcasts": {
            "type": "boolean",
            "description": "Whether to keep only one episode per podcast for episode searches."
          }
        },
        "additionalProperties": false,
        "required": [
