  "actions": [
    {
      "id": "listennotes.get_best_podcasts",
      "service": "listennotes",
      "name": "get_best_podcasts",
      "description": "Get ranked best podcasts from Listen Notes with optional directory filters.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "The best podcasts page number to retrieve."
          },
          "sort": {
            "type": "string",
            "enum": [
              "listen_score",
              "oldest_added_first",
              "oldest_published_first",
              "recent_added_first",
              "recent_published_first"
            ],
            "description": "The ranking sort applied to best podcasts results."
          },
          "region": {
            "type": "string",
            "minLength": 1,
            "description": "The region code used to rank best podcasts."
          },
          "genreId": {
            "type": "integer",
            "minimum": 1,
            "description": "One Listen Notes genre identifier."
          },
          "language": {
            "type": "string",
            "minLength": 1,
            "description": "The language label used to filter best podcasts."
          },
          "safeMode": {
            "type": "boolean",
            "description": "Whether to exclude explicit podcasts."
          },
          "publisherRegion": {
            "type": "string",
            "minLength": 1,
            "description": "The publisher region code used to filter best podcasts."
          }
        },
        "additionalProperties": false,
        "description": "Input for Listen Notes best podcasts."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "integer",
                "description": "The best podcasts genre identifier."
              },
              {
                "type": "null"
              }
            ]
          },
          "name": {
            "anyOf": [
              {
                "type": "string",
                "description": "The best podcasts genre name."
              },
              {
                "type": "null"
              }
            ]
          },
          "parentId": {
            "anyOf": [
              {
                "type": "integer",
                "description": "The parent genre identifier."
              },
              {
                "type": "null"
              }
            ]
          },
          "total": {
            "type": "integer",
            "description": "The total number of ranked podcasts."
          },
          "pageNumber": {
            "type": "integer",
            "description": "The current page number."
          },
          "hasNext": {
            "type": "boolean",
            "description": "Whether there is a next page."
          },
          "hasPrevious": {
            "type": "boolean",
            "description": "Whether there is a previous page."
          },
          "nextPageNumber": {
            "anyOf": [
              {
                "type": "integer",
                "description": "The next page number when available."
              },
              {
                "type": "null"
              }
            ]
          },
          "previousPageNumber": {
            "anyOf": [
              {
                "type": "integer",
                "description": "The previous page number when available."
              },
              {
                "type": "null"
              }
            ]
          },
          "podcasts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "podcast",
                  "type": "string",
                  "description": "The fixed result kind for podcast items."
                },
                "id": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The Listen Notes podcast identifier."
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The podcast title."
                },
                "publisher": {
                  "type": "string",
                  "description": "The podcast publisher name."
                },
                "description": {
                  "type": "string",
                  "description": "The podcast description text."
                },
                "image": {
                  "type": "string",
                  "description": "The podcast artwork image URL."
                },
                "thumbnail": {
                  "type": "string",
                  "description": "The podcast artwork thumbnail URL."
                },
                "listennotesUrl": {
                  "type": "string",
                  "description": "The Listen Notes public podcast URL."
                },
                "language": {
                  "type": "string",
                  "description": "The podcast language label."
                },
                "country": {
                  "type": "string",
                  "description": "The podcast country label."
                },
                "genreIds": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "One Listen Notes genre identifier."
                  },
                  "description": "The Listen Notes genre identifiers attached to the podcast."
                },
                "totalEpisodes": {
                  "type": "integer",
                  "description": "The total number of podcast episodes."
                },
                "latestPubDateMs": {
                  "type": "integer",
                  "description": "The latest episode publication timestamp in milliseconds."
                },
                "explicitContent": {
                  "type": "boolean",
                  "description": "Whether the podcast contains explicit content."
                },
                "rss": {
                  "type": "string",
                  "description": "The podcast RSS feed URL."
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "episodic",
                    "serial"
                  ],
                  "description": "The podcast release format returned by Listen Notes."
                },
                "website": {
                  "type": "string",
                  "description": "The canonical podcast website URL."
                },
                "raw": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true,
                  "description": "A raw Listen Notes object returned by the upstream API."
                }
              },
              "additionalProperties": false,
              "required": [
                "kind",
                "id",
                "title",
                "raw"
              ],
              "description": "A normalized podcast result item."
            },
            "description": "The ranked podcasts returned by Listen Notes."
          }
        },
        "additionalProperties": false,
        "description": "Normalized output payload for Listen Notes best podcasts."
      }
    },
