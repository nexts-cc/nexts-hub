                "name": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "The ShipBob location name."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "abbreviation": {
                  "anyOf": [
                    {
                      "type": "string",
