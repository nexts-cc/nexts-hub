                    }
                  ]
                },
                "selected_branch": {
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1,
                      "description": "Branch selected for the conversation."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "title": {
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1,
                      "description": "Conversation title."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "sandbox_status": {
                  "type": "string",
                  "enum": [
                    "STARTING",
                    "RUNNING",
                    "PAUSED",
                    "ERROR",
                    "MISSING"
                  ],
                  "description": "OpenHands sandbox status."
                },
                "execution_status": {
                  "anyOf": [
                    {
                      "type": "string",
                      "enum": [
                        "idle",
                        "running",
                        "paused",
                        "waiting_for_confirmation",
                        "finished",
                        "error",
                        "stuck",
                        "deleting"
                      ],
                      "description": "OpenHands agent execution status when the sandbox is running."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "conversation_url": {
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1,
