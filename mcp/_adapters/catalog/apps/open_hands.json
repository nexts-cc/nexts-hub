                "type": "null"
              }
            ]
          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Raw OpenHands response payload."
          }
        },
        "additionalProperties": false,
        "required": [
          "success",
          "sandbox_status",
          "message",
          "raw"
        ],
        "description": "OpenHands send message response."
      }
