  ],
  "auth": [
    {
      "type": "api_key",
      "label": "API Access Token",
      "placeholder": "bkua_...",
      "description": "Buildkite API access token used with the Authorization Bearer header. Create it from Personal Settings > API Access Tokens at https://buildkite.com/user/api-access-tokens.",
