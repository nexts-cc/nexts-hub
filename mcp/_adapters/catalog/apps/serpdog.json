            "description": "Grouped sub-articles returned by Serpdog when available."
          },
          "pagination": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Google pagination payload returned by Serpdog."
          },
          "serpdog_pagination": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Serpdog pagination helper payload returned by Serpdog."
          }
        },
        "additionalProperties": false,
        "required": [
          "meta",
          "news_results"
        ],
        "description": "Normalized output payload for google_news_search."
