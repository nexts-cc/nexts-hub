      "id": "serpdog.google_news_search",
      "service": "serpdog",
      "name": "google_news_search",
      "description": "Run a Google News request through Serpdog.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "minLength": 1,
            "description": "Google News query."
          },
          "num": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of results to request per page."
          },
          "gl": {
            "type": "string",
            "minLength": 1,
            "description": "Two-letter country code used for localized results."
          },
          "hl": {
            "type": "string",
            "minLength": 1,
            "description": "Language code used for localized results."
          },
          "page": {
            "type": "integer",
            "minimum": 0,
            "description": "Result offset used by Serpdog pagination, such as 0, 10, or 20."
          },
          "lr": {
            "type": "string",
            "minLength": 1,
            "description": "Document language restriction passed to Google News."
          },
          "uule": {
            "type": "string",
            "minLength": 1,
            "description": "Encoded location parameter passed to Google News."
          },
          "duration": {
            "type": "string",
            "minLength": 1,
            "description": "Relative time filter passed to Google News."
          },
          "nfpr": {
            "type": "boolean",
            "description": "Whether to exclude results for an auto-corrected query."
          },
          "tbs": {
            "type": "string",
            "minLength": 1,
            "description": "Advanced search filter string passed to Google News."
          },
          "safe": {
            "type": "string",
            "enum": [
              "active",
              "off"
            ],
            "description": "Safe search mode passed to Google News."
          }
        },
        "additionalProperties": false,
        "required": [
          "q"
        ],
        "description": "Input parameters for running a Google News request through Serpdog."
