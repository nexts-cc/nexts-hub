{
  "service": "serpdog",
  "displayName": "Serpdog",
  "categories": [
    "Data"
  ],
  "authTypes": [
    "api_key"
  ],
  "auth": [
    {
      "type": "api_key",
      "label": "API Key",
      "placeholder": "SERPDOG_API_KEY",
      "description": "Serpdog API key passed as the api_key query parameter. The official Account API docs show it in the account_info response: https://docs.serpdog.io/account-api."
    }
  ],
  "homepageUrl": "https://serpdog.io",
  "actions": [
    {
      "id": "serpdog.get_account_info",
      "service": "serpdog",
      "name": "get_account_info",
      "description": "Retrieve account details and quota usage for the connected Serpdog API key.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false,
        "description": "The input payload for retrieving Serpdog account information."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "user_name": {
            "type": "string",
            "minLength": 1,
            "description": "The user name returned by Serpdog."
          },
          "api_key": {
            "type": "string",
            "minLength": 1,
            "description": "The API key echoed by Serpdog."
          },
          "email": {
            "type": "string",
            "minLength": 1,
            "description": "The account email address returned by Serpdog."
          },
          "plan": {
            "type": "string",
            "minLength": 1,
            "description": "The current Serpdog plan name."
          },
          "quota": {
            "type": "integer",
            "minimum": 0,
            "description": "The monthly quota returned by Serpdog."
          },
          "requests": {
            "type": "integer",
            "minimum": 0,
            "description": "The number of requests already used in the current period."
          },
          "requests_left": {
            "type": "integer",
            "minimum": 0,
            "description": "The number of requests remaining in the current period."
          },
          "billing_history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The billing event timestamp."
                },
                "plan": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The billed plan name."
                },
                "amount": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The billed amount string."
                },
                "invoice": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The invoice URL or label returned by Serpdog."
                }
              },
              "additionalProperties": false,
              "description": "One Serpdog billing history entry."
            },
            "description": "The billing history entries returned by Serpdog when available."
          }
        },
        "additionalProperties": false,
        "required": [
          "user_name",
          "api_key",
          "email",
          "plan",
          "quota",
          "requests",
          "requests_left"
        ],
        "description": "Account information payload returned by Serpdog."
      }
    },
    {
      "id": "serpdog.google_autocomplete",
      "service": "serpdog",
      "name": "google_autocomplete",
      "description": "Retrieve Google Autocomplete suggestions through Serpdog.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "minLength": 1,
            "description": "Google Autocomplete query."
          },
          "gl": {
            "type": "string",
            "minLength": 1,
            "description": "Two-letter country code used for localized suggestions."
          },
          "hl": {
            "type": "string",
            "minLength": 1,
            "description": "Language code used for localized suggestions."
          }
        },
        "additionalProperties": false,
        "required": [
          "q"
        ],
        "description": "Input parameters for running a Google Autocomplete request through Serpdog."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Request metadata returned by Serpdog."
          },
          "suggestions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Suggestion text returned by Serpdog."
                },
                "relevance": {
                  "type": "integer",
                  "description": "Suggestion relevance score returned by Serpdog."
                },
                "type": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Suggestion type returned by Serpdog."
                }
              },
              "additionalProperties": false,
              "description": "One autocomplete suggestion item."
            },
            "description": "Autocomplete suggestions returned by Serpdog."
          },
          "verbatim_relevance": {
            "type": "integer",
            "description": "Verbatim relevance score returned by Serpdog."
          }
        },
        "additionalProperties": false,
        "required": [
          "meta",
          "suggestions",
          "verbatim_relevance"
        ],
        "description": "Normalized output payload for google_autocomplete."
      }
    },
