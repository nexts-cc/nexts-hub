        "additionalProperties": false,
        "required": [
          "id"
        ],
        "description": "Input parameters for retrieving one Metabase card."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "card": {
            "type": "object",
            "properties": {},
