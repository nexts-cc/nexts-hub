    {
      "id": "metabase.get_card",
      "service": "metabase",
      "name": "get_card",
      "description": "Retrieve one Metabase card by ID.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1,
                "description": "A positive numeric Metabase ID."
              },
              {
                "type": "string",
                "minLength": 1,
                "description": "A Metabase entity ID string."
              }
            ],
            "description": "A Metabase numeric ID or entity ID string."
          },
          "legacyMbql": {
            "type": "boolean",
            "description": "Whether to request the legacy MBQL response shape."
          }
