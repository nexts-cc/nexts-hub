                "description": "NetHunt record ID associated with the call log."
              },
              "createdAt": {
                "type": "string",
                "description": "Call log creation timestamp returned by NetHunt."
              },
              "text": {
                "type": "string",
                "description": "Call log text."
              },
              "duration": {
                "type": "number",
                "description": "Call duration in minutes."
              },
