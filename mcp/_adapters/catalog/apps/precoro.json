      "id": "precoro.list_items",
      "service": "precoro",
      "name": "list_items",
      "description": "List Precoro catalog items with pagination and optional modified-since filtering.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "modifiedSince": {
            "type": "string",
            "minLength": 1,
            "description": "Return records created or modified since this UTC timestamp."
          },
          "per_page": {
            "type": "integer",
            "description": "Number of records per page. Precoro supports 10, 20, 50, 100, or 200."
          },
          "page": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1,
                "description": "A positive page number."
              },
              {
                "const": "last",
                "type": "string",
                "description": "The last page marker."
              }
            ],
            "description": "The page number to request, or last to request the final page."
          },
          "externalIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1,
              "description": "One numeric external ID."
            },
            "description": "External IDs to pass as repeated external_id[] filters. Precoro supports up to 200 values.",
            "maxItems": 200
          }
        },
        "additionalProperties": false,
        "description": "Common Precoro list filters."
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true,
