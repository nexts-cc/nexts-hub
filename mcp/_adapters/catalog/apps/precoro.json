            },
            "description": "Records returned by Precoro."
          },
          "pagination": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Pagination metadata returned by Precoro."
          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Additional upstream fields returned by Precoro."
          }
        },
        "additionalProperties": false,
        "description": "A page of Precoro catalog items."
