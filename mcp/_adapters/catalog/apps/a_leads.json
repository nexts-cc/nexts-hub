  "homepageUrl": "https://a-leads.co",
  "actions": [
    {
      "id": "a_leads.find_email",
      "service": "a_leads",
      "name": "find_email",
      "description": "Find a business email address from a person's name and company website or A-Leads document ID.",
      "requiredScopes": [],
      "providerPermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string",
            "pattern": "\\S",
            "description": "First name of the person."
          },
          "last_name": {
            "type": "string",
            "pattern": "\\S",
            "description": "Last name of the person."
          },
          "website": {
            "type": "string",
            "pattern": "\\S",
            "description": "Company website or domain."
          },
          "document_id": {
            "type": "string",
            "pattern": "\\S",
            "description": "Unique document ID from A-Leads advanced search results."
          },
          "request_uuid": {
            "type": "string",
            "pattern": "\\S",
            "description": "A unique ID linked to the search request for tracking in A-Leads."
          }
        },
        "additionalProperties": false,
        "description": "Input parameters for finding a business email with A-Leads.",
        "anyOf": [
          {
            "required": [
              "document_id"
            ]
          },
          {
            "required": [
              "first_name",
              "last_name",
              "website"
            ]
          }
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "A-Leads operation status."
              },
              "statusCode": {
                "type": "integer",
                "description": "HTTP-like status code returned by A-Leads."
              },
              "description": {
                "type": "string",
                "description": "Human-readable response description returned by A-Leads."
              }
            },
            "additionalProperties": true,
            "description": "A-Leads response message metadata."
          },
          "response": {
            "type": "object",
            "properties": {
              "email": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Business email address found by A-Leads."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "quality": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Email quality rating returned by A-Leads."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "result": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Email finder result code returned by A-Leads."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "first_name": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "First name returned by A-Leads."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "last_name": {
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Last name returned by A-Leads."
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "catch_all_status": {
                "anyOf": [
                  {
                    "type": "boolean",
                    "description": "Whether the company email domain is catch-all."
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "additionalProperties": true,
            "description": "A-Leads email finder result."
          },
          "raw": {
            "type": "object",
            "properties": {},
            "additionalProperties": true,
            "description": "Raw A-Leads response payload."
          }
        },
        "additionalProperties": false,
        "required": [
          "message",
          "response",
          "raw"
        ],
        "description": "A-Leads business email lookup response."
      }
    },
