    "Marketing",
    "Data"
  ],
  "authTypes": [
    "api_key"
  ],
  "auth": [
    {
      "type": "api_key",
      "label": "API Key",
      "placeholder": "A_LEADS_API_KEY",
      "description": "A-Leads API key sent with the x-api-key header. Create or view it in your A-Leads account, and see the API docs at https://docs.a-leads.co/docs."
